#!/usr/bin/env bash
# Demo stand-in for `ssh`, used when recording VHS GIFs and by demo/play.sh.
#
# SSHub spawns `ssh <host>` on a PTY (embedded session). The demo prepends
# demo/bin to PATH, so this script shadows the real ssh and renders a
# believable remote session — a fake shell whose common commands (uname,
# hostname, ls, df, …) answer as if you were really on <host>, instead of
# leaking the local machine. Do NOT install this on your PATH outside demos.

host="${!#}"     # last positional arg == the ssh target
host="${host##*@}"  # strip any user@ prefix for display
[ -z "$host" ] && host="demo-vm"

here="$(cd "$(dirname "$0")" && pwd)"

# sshub siphons the child's stderr (fd 2) into a side channel to hide ssh's
# `-v` handshake, and keys its "connecting → connected" header off it. Emit a
# believable handshake there, including the "Authenticated to" marker sshub
# looks for, so the session reads as genuinely connected.
{
    printf 'OpenSSH_9.6p1 Ubuntu-3ubuntu13, OpenSSL 3.0.13\n'
    printf 'debug1: Connecting to %s [%s] port 22.\n' "$host" "$host"
    printf 'debug1: Connection established.\n'
    printf 'debug1: Server host key: ssh-ed25519 SHA256:9c1a…demo\n'
    printf 'debug1: Host '\''%s'\'' is known and matches the ED25519 host key.\n' "$host"
    printf 'debug1: Authenticated to %s ([%s]:22) using "publickey".\n' "$host" "$host"
    printf 'debug1: channel 0: new session\n'
} >&2

sleep 0.4
printf '\n'
printf 'Welcome to %s — Ubuntu 24.04.1 LTS (GNU/Linux 6.8.0-45-generic x86_64)\n\n' "$host"
printf ' * Documentation:  https://help.ubuntu.com\n'
printf ' * Management:     https://landscape.canonical.com\n'
printf ' * Support:        https://ubuntu.com/pro\n\n'
printf 'Last login: Tue Jun 10 13:37:00 2026 from 10.0.0.42\n\n'

# Build an rcfile that fakes a remote box. Interactive bash sources it, so the
# functions below shadow the real binaries and the prompt looks like the server.
rc="$(mktemp)"
cat >"$rc" <<RC
# Make the demo cowsay reachable inside the session.
export PATH="$here:\$PATH"
export HOSTNAME="$host"
export USER="deploy"
PS1="\[\e[32m\]deploy@$host\[\e[0m\]:\[\e[34m\]\w\[\e[0m\]\\\$ "
umask 022
cd /home/deploy 2>/dev/null || cd "\$HOME"

hostname() { echo "$host"; }
whoami()   { echo "deploy"; }
id()       { echo "uid=1000(deploy) gid=1000(deploy) groups=1000(deploy),27(sudo)"; }

uname() {
    case "\$*" in
        *a*) echo "Linux $host 6.8.0-45-generic #45-Ubuntu SMP PREEMPT_DYNAMIC x86_64 GNU/Linux" ;;
        *r*) echo "6.8.0-45-generic" ;;
        *)   echo "Linux" ;;
    esac
}

uptime() { echo " 13:37:12 up 27 days,  4:11,  1 user,  load average: 0.08, 0.03, 0.01"; }

ls() {
    if [ "\$1" = "-l" ] || [ "\$1" = "-la" ] || [ "\$1" = "-al" ]; then
        cat <<'LS'
total 28
drwxr-xr-x 4 deploy deploy 4096 Jun 10 13:20 .
drwxr-xr-x 3 root   root   4096 May 02 09:14 ..
-rw-r--r-- 1 deploy deploy  220 May 02 09:14 .bash_logout
-rw-r--r-- 1 deploy deploy 3771 May 02 09:14 .bashrc
drwxr-xr-x 2 deploy deploy 4096 Jun 10 13:20 app
drwxr-xr-x 2 deploy deploy 4096 Jun 08 11:02 logs
-rw-r--r-- 1 deploy deploy   64 Jun 10 13:20 deploy.sh
LS
    else
        echo "app  deploy.sh  logs"
    fi
}

df() {
    cat <<'DF'
Filesystem      Size  Used Avail Use% Mounted on
/dev/vda1        79G   21G   55G  28% /
tmpfs           3.9G     0  3.9G   0% /dev/shm
DF
}

free() {
    cat <<'FREE'
               total        used        free      shared  buff/cache   available
Mem:           7976        1893        3120         112        2962        5742
Swap:          2047           0        2047
FREE
}

cat() {
    if [ "\$1" = "/etc/os-release" ]; then
        printf 'PRETTY_NAME="Ubuntu 24.04.1 LTS"\nNAME="Ubuntu"\nVERSION_ID="24.04"\nVERSION="24.04.1 LTS (Noble Numbat)"\nID=ubuntu\n'
    else
        command cat "\$@"
    fi
}
RC

# Clean the temp rcfile up when the session ends.
trap 'rm -f "$rc"' EXIT
# Redirect bash's stderr onto the PTY (fd 1): an interactive bash writes its
# prompt and readline output to stderr, which sshub otherwise siphons off the
# grid — so without this the prompt would be invisible.
exec bash --rcfile "$rc" -i 2>&1
